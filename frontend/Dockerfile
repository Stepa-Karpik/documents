FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_DOCUMENTS_API_BASE_URL=http://localhost:8200
ARG NEXT_PUBLIC_FILES_API_BASE_URL=http://localhost:8320
ARG NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL=http://localhost:8310
ARG NEXT_PUBLIC_ONLYOFFICE_BASE_URL=http://localhost:8088
ENV NEXT_PUBLIC_DOCUMENTS_API_BASE_URL=$NEXT_PUBLIC_DOCUMENTS_API_BASE_URL
ENV NEXT_PUBLIC_FILES_API_BASE_URL=$NEXT_PUBLIC_FILES_API_BASE_URL
ENV NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL=$NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL
ENV NEXT_PUBLIC_ONLYOFFICE_BASE_URL=$NEXT_PUBLIC_ONLYOFFICE_BASE_URL
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ARG NEXT_PUBLIC_DOCUMENTS_API_BASE_URL=http://localhost:8200
ARG NEXT_PUBLIC_FILES_API_BASE_URL=http://localhost:8320
ARG NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL=http://localhost:8310
ARG NEXT_PUBLIC_ONLYOFFICE_BASE_URL=http://localhost:8088
ENV NEXT_PUBLIC_DOCUMENTS_API_BASE_URL=$NEXT_PUBLIC_DOCUMENTS_API_BASE_URL
ENV NEXT_PUBLIC_FILES_API_BASE_URL=$NEXT_PUBLIC_FILES_API_BASE_URL
ENV NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL=$NEXT_PUBLIC_INTEGRATIONS_API_BASE_URL
ENV NEXT_PUBLIC_ONLYOFFICE_BASE_URL=$NEXT_PUBLIC_ONLYOFFICE_BASE_URL
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/package.json ./package.json
COPY --from=deps /app/node_modules ./node_modules
EXPOSE 3000
CMD ["npm", "run", "start"]
